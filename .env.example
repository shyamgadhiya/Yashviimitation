# Copy these values into `.env.local` for local development.
# Add the same variables in Cloudflare Pages:
# Settings > Environment variables
#
# These are build-time public frontend variables for the Vite app.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key
VITE_SITE_URL=https://yourdomain.com
# Optional: add Google Analytics only after creating a GA4 property.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional: only if you choose Search Console HTML tag verification instead of DNS verification.
VITE_GOOGLE_SITE_VERIFICATION=your-google-site-verification-code
